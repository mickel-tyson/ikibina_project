        function showSection(section) {
            // Hide all sections
            document.querySelectorAll('.section-content').forEach(el => {
                el.style.display = 'none';
            });
            
            // Show selected section
            const sectionElement = document.getElementById(section + '-section');
            if (sectionElement) {
                sectionElement.style.display = 'block';
            }
            
            // Update nav links
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // Load data for section
            if (section === 'members') {
                loadMembers();
            }
        }

        async function loadDashboard() {
            try {
                // Load group info
                const groupData = await apiCall('/api/chief/my-group');
                if (groupData && groupData.group) {
                    const group = groupData.group;
                    document.getElementById('groupName').textContent = group.group_name || 'No group assigned';
                    document.getElementById('contributionAmount').textContent = `RWF ${group.contribution_amount || 0}`;
                    document.getElementById('frequency').textContent = group.frequency || '-';
                    document.getElementById('district').textContent = group.district || '-';
                    document.getElementById('sector').textContent = group.sector || '-';
                    document.getElementById('village').textContent = group.village || '-';
                    document.getElementById('nextDrawDate').textContent = group.draw_day || 'Not set';
                }
                
                // Load members for stats
                const membersData = await apiCall('/api/chief/members');
                if (membersData && membersData.members) {
                    const members = membersData.members;
                    document.getElementById('totalMembers').textContent = members.length;
                    
                    // Calculate stats (simplified)
                    const paidCount = members.filter(m => m.status === 'active').length;
                    document.getElementById('paidThisCycle').textContent = paidCount;
                    document.getElementById('unpaidThisCycle').textContent = members.length - paidCount;
                    document.getElementById('attendanceRate').textContent = Math.round((paidCount / members.length) * 100) + '%';
                    document.getElementById('groupWallet').textContent = `RWF ${(paidCount * 5000).toLocaleString()}`;
                }
                
                document.getElementById('pendingLoans').textContent = '0';
                
            } catch (error) {
                console.error('Error loading dashboard:', error);
                // Show default values
                document.getElementById('groupName').textContent = 'No group assigned';
                document.getElementById('totalMembers').textContent = '0';
                document.getElementById('paidThisCycle').textContent = '0';
                document.getElementById('unpaidThisCycle').textContent = '0';
                document.getElementById('attendanceRate').textContent = '0%';
            }
        }

