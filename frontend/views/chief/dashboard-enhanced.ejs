<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --sidebar-width: 250px;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: var(--primary-gradient);
            transition: all 0.3s;
            z-index: 1000;
            overflow-y: auto;
        }
        
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            min-height: 100vh;
            transition: margin-left 0.3s;
        }
        
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 1rem 1.5rem;
            border-radius: 0;
            transition: all 0.3s;
        }
        
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: white;
            background-color: rgba(255, 255, 255, 0.1);
        }
        
            min-height: 100vh;
        }
        
        .stat-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: all 0.3s;
            border-left: 4px solid #667eea;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            background: var(--primary-gradient);
        }
        
        .btn-primary {
            background: var(--primary-gradient);
            border: none;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
        }
        
        .section-content {
            display: none;
        }
        
        .section-content.active {
            display: block;
        }
        
        .draw-card {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            border-radius: 1rem;
            padding: 2rem;
            text-align: center;
        }
        
        .winner-animation {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        .attendance-badge {
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-size: 0.875rem;
            font-weight: 600;
        }
        
        .attendance-present { background-color: #28a745; color: white; }
        .attendance-absent { background-color: #dc3545; color: white; }
        .attendance-late { background-color: #ffc107; color: black; }
        
        .member-card {
            transition: all 0.3s;
        }
        
        .member-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .navbar-brand {
            color: white !important;
            font-weight: bold;
            font-size: 1.5rem;
        }
        
        .user-info {
            color: white;
            padding: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .modal-header {
            background: var(--primary-gradient);
            color: white;
        }
        
        .form-control:focus,
        .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        
        .draw-wheel {
            width: 200px;
            height: 200px;
            border: 8px solid #667eea;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            background: white;
            position: relative;
            animation: spin 3s linear infinite paused;
        }
        
        .draw-wheel.spinning {
            animation-play-state: running;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="p-3">
            <div class="navbar-brand">
                <i class="bi bi-shield-check me-2"></i>
                Ikibina Guardian
            </div>
        </div>
        
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link active" href="#" onclick="showSection(event, 'dashboard')">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'members')">
                    <i class="bi bi-people me-2"></i> Members
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'contributions')">
                    <i class="bi bi-cash-stack me-2"></i> Contributions
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'attendance')">
                    <i class="bi bi-calendar-check me-2"></i> Attendance
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'draw')">
                    <i class="bi bi-dice-5 me-2"></i> Smart Draw
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'voting')">
                    <i class="bi bi-balloon-heart me-2"></i> Voting
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'fines')">
                    <i class="bi bi-cash-coin me-2"></i> Fines
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'loans')">
                    <i class="bi bi-bank me-2"></i> Loans
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'meetings')">
                    <i class="bi bi-calendar-event me-2"></i> Meetings
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'notifications')">
                    <i class="bi bi-bell me-2"></i> Notifications
                </a>
            </li>
        </ul>
        
        <div class="user-info">
            <div class="d-flex align-items-center">
                <i class="bi bi-person-badge me-2"></i>
                <div>
                    <div class="fw-bold"><%= user.full_name %></div>
                    <small>Group Chief</small>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-light mt-2 w-100" onclick="logout()">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Chief Dashboard</h1>
            <div>
                <button class="btn btn-outline-secondary me-2" onclick="refreshData()">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button class="btn btn-primary" onclick="exportReport()">
                    <i class="bi bi-download"></i> Export Report
                </button>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" class="section-content active">
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalMembers">0</h3>
                                <p class="text-muted mb-0">Total Members</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-people"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="paidThisCycle">0</h3>
                                <p class="text-muted mb-0">Paid This Cycle</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="unpaidThisCycle">0</h3>
                                <p class="text-muted mb-0">Unpaid This Cycle</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-clock"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="attendanceRate">0%</h3>
                                <p class="text-muted mb-0">Attendance Rate</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-graph-up"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1" id="nextDrawDate">-</h5>
                                <p class="text-muted mb-0">Next Draw Date</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="pendingLoans">0</h3>
                                <p class="text-muted mb-0">Pending Loans</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-hourglass-split"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="groupWallet">0</h3>
                                <p class="text-muted mb-0">Group Wallet</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-wallet2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Activity</h5>
                </div>
                <div class="card-body">
                    <div id="recentActivity">
                        <!-- Recent activities will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Members Section -->
        <div id="members-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Member Management</h5>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                        <i class="bi bi-plus-circle"></i> Add Member
                    </button>
                </div>
                <div class="card-body">
                    <div class="row g-3" id="membersGrid">
                        <!-- Members will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Contributions Section -->
        <div id="contributions-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Contribution Management</h5>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#recordContributionModal">
                        <i class="bi bi-plus-circle"></i> Record Payment
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Amount</th>
                                    <th>Cycle</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="contributionsTable">
                                <!-- Contributions will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attendance Section -->
        <div id="attendance-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Attendance Management</h5>
                    <div>
                        <input type="date" class="form-control d-inline-block w-auto me-2" id="meetingDate">
                        <button class="btn btn-primary" onclick="markAttendanceMode()">
                            <i class="bi bi-check2-square"></i> Mark Attendance
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3" id="attendanceGrid">
                        <!-- Attendance will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Smart Draw Section -->
        <div id="draw-section" class="section-content">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Smart Draw System</h5>
                        </div>
                        <div class="card-body text-center">
                            <div class="draw-wheel" id="drawWheel">
                                <i class="bi bi-dice-5" style="font-size: 3rem; color: #667eea;"></i>
                            </div>
                            <h4 class="mt-3" id="drawStatus">Ready to Draw</h4>
                            <p class="text-muted" id="eligibleCount">0 eligible members</p>
                            <button class="btn btn-primary btn-lg mt-3" id="startDrawBtn" onclick="startDraw()">
                                <i class="bi bi-play-circle"></i> Start Draw
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Draw History</h5>
                        </div>
                        <div class="card-body">
                            <div id="drawHistory">
                                <!-- Draw history will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loans Section -->
        <div id="loans-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Loan Management</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Amount</th>
                                    <th>Reason</th>
                                    <th>Status</th>
                                    <th>Balance</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="loansTable">
                                <!-- Loans will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Meetings Section -->
        <div id="meetings-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Meeting Management</h5>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#scheduleMeetingModal">
                        <i class="bi bi-plus-circle"></i> Schedule Meeting
                    </button>
                </div>
                <div class="card-body">
                    <div id="meetingsList">
                        <!-- Meetings will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Voting Section -->
        <div id="voting-section" class="section-content">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Voting Management</h5>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#startVotingModal">
                                <i class="bi bi-plus-circle"></i> Start Voting
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="votingType" class="form-label">Voting Type</label>
                                <select class="form-select" id="votingType">
                                    <option value="simple">Simple Majority</option>
                                    <option value="weighted">Weighted Voting</option>
                                    <option value="consensus">Consensus</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="votingRules" class="form-label">Voting Rules</label>
                                <textarea class="form-control" id="votingRules" rows="3" placeholder="Enter voting rules..."></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="votingDuration" class="form-label">Duration (minutes)</label>
                                <input type="number" class="form-control" id="votingDuration" value="30">
                            </div>
                            <button class="btn btn-primary w-100" onclick="startVotingSession()">
                                <i class="bi bi-play-circle"></i> Start Voting Session
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Current Voting Status</h5>
                        </div>
                        <div class="card-body">
                            <div id="votingStatus">
                                <div class="text-center text-muted">
                                    <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
                                    <p class="mt-3">No active voting session</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Voting History</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Topic</th>
                                    <th>Winner</th>
                                    <th>Payment Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="votingHistory">
                                <!-- Voting history will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fines Section -->
        <div id="fines-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Fine Management</h5>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createFineModal">
                        <i class="bi bi-plus-circle"></i> Create Fine
                    </button>
                </div>
                <div class="card-body">
                    <div class="row g-4 mb-4">
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="totalFines">0</h3>
                                        <p class="text-muted mb-0">Total Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-cash-coin"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="paidFines">0</h3>
                                        <p class="text-muted mb-0">Paid Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-check-circle"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="pendingFines">0</h3>
                                        <p class="text-muted mb-0">Pending Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-clock"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="unpaidFines">0</h3>
                                        <p class="text-muted mb-0">Unpaid Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-x-circle"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="finesTable">
                                <!-- Fines will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Section -->
        <div id="notifications-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Send Notifications</h5>
                </div>
                <div class="card-body">
                    <form id="notificationForm">
                        <div class="mb-3">
                            <label for="notificationTitle" class="form-label">Title</label>
                            <input type="text" class="form-control" id="notificationTitle" required>
                        </div>
                        <div class="mb-3">
                            <label for="notificationMessage" class="form-label">Message</label>
                            <textarea class="form-control" id="notificationMessage" rows="3" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="notificationType" class="form-label">Type</label>
                            <select class="form-select" id="notificationType">
                                <option value="meeting">Meeting Reminder</option>
                                <option value="payment">Payment Reminder</option>
                                <option value="draw">Draw Announcement</option>
                                <option value="general">General</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send"></i> Send Notification
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Member Modal -->
    <div class="modal fade" id="addMemberModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
