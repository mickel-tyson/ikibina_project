    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentData = {};
        let isDrawing = false;

        // Authentication check
        let authChecked = false;
        function checkAuth() {
            if (authChecked) {
                console.log('Auth already checked, preventing redirect loop');
                return JSON.parse(sessionStorage.getItem('user') || '{}');
            }
            
            const user = sessionStorage.getItem('user');
            console.log('Chief dashboard - Checking auth, user:', user);
            if (!user) {
                console.log('Chief dashboard - No user found, redirecting to login');
                window.location.href = '/login';
                return false;
            }
            try {
                const parsedUser = JSON.parse(user);
                console.log('Chief dashboard - User authenticated:', parsedUser);
                authChecked = true;
                return parsedUser;
            } catch (error) {
                console.error('Chief dashboard - Error parsing user data:', error);
                sessionStorage.removeItem('user');
                window.location.href = '/login';
                return false;
            }
        }

        async function apiCall(url, options = {}) {
            const defaultOptions = {
                headers: {
                    'Content-Type': 'application/json'
                }
            };
            
            const finalOptions = {
                ...defaultOptions,
                ...options,
                headers: {
                    ...defaultOptions.headers,
                    ...options.headers
                }
            };
            
            try {
                const response = await fetch(url, finalOptions);
                
                // Don't clear sessionStorage on 401, let's auth check handle it
                if (!response.ok) {
                    console.error('API call failed:', response.status, response.statusText);
                    return null;
                }
                
                return await response.json();
            } catch (error) {
                console.error('API call error:', error);
                return null;
            }
        }

        function logout() {
            sessionStorage.removeItem('user');
            window.location.href = '/login';
        }

        // Section Management
        function showSection(evt, section) {
            evt.preventDefault();
            const sections = ['dashboard', 'members', 'contributions', 'attendance', 'draw', 'loans', 'meetings', 'notifications', 'voting', 'fines'];
            sections.forEach(s => {
                const element = document.getElementById(`${s}-section`);
                if (element) {
                    element.classList.toggle('active', s === section);
                    element.style.display = s === section ? 'block' : 'none';
                }
            });

            const navLinks = document.querySelectorAll('.sidebar .nav-link');
            navLinks.forEach(link => link.classList.remove('active'));
            
            const clickedLink = evt.target.closest('.nav-link');
            if (clickedLink) {
                clickedLink.classList.add('active');
            }

            loadData(section);
        }

        async function loadData(section) {
            switch(section) {
                case 'dashboard':
                    await loadDashboard();
                    break;
                case 'members':
                    await loadMembers();
                    break;
                case 'contributions':
                    await loadContributions();
                    break;
                case 'attendance':
                    await loadAttendance();
                    break;
                case 'draw':
                    await loadDrawData();
                    break;
                case 'voting':
                    await loadVoting();
                    break;
                case 'fines':
                    await loadFines();
                    break;
                case 'loans':
                    await loadLoans();
                    break;
                case 'meetings':
                    await loadMeetings();
                    break;
                case 'notifications':
                    await loadNotifications();
                    break;
            }
        }

        // Dashboard Functions
        async function loadDashboard() {
            const groupData = await apiCall('/api/chief/my-group');
            const membersData = await apiCall('/api/chief/members');
            
            if (groupData && membersData) {
                const group = groupData.group;
                const members = membersData.members;
                
                document.getElementById('totalMembers').textContent = members.length;
                document.getElementById('nextDrawDate').textContent = group.draw_day || 'Not set';
                
                // Calculate statistics
                const paidCount = members.filter(m => m.status === 'active').length;
                document.getElementById('paidThisCycle').textContent = paidCount;
                document.getElementById('unpaidThisCycle').textContent = members.length - paidCount;
                document.getElementById('attendanceRate').textContent = Math.round((paidCount / members.length) * 100) + '%';
                
                // Load recent activity
                loadRecentActivity();
            }
        }

        // Members Functions
        async function loadMembers() {
            const data = await apiCall('/api/chief/members');
            if (data) {
                displayMembers(data.members);
                // Populate fine member dropdown
                const fineMemberSelect = document.getElementById('fineMember');
                if (fineMemberSelect) {
                    const memberOptions = data.members.map(m => `<option value="${m.id}">${m.full_name}</option>`).join('');
                    fineMemberSelect.innerHTML = '<option value="">Select Member</option>' + memberOptions;
                }
            }
        }

        // Contributions Functions
        async function loadContributions() {
            const data = await apiCall('/api/chief/contributions');
            const tbody = document.getElementById('contributionsTable');
            if (!tbody) return;

            const contributions = data?.contributions || [];
            if (!contributions.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No contributions recorded yet</td></tr>';
                return;
            }

            tbody.innerHTML = contributions.map(contribution => `
                <tr>
                    <td>${contribution.member_name || 'N/A'}</td>
                    <td>RWF ${Number(contribution.amount || 0).toLocaleString()}</td>
                    <td>${contribution.payment_cycle || 'N/A'}</td>
                    <td><span class="badge bg-${contribution.status === 'paid' ? 'success' : 'warning'}">${contribution.status || 'pending'}</span></td>
                    <td>${contribution.created_at ? new Date(contribution.created_at).toLocaleDateString() : '-'}</td>
                    <td class="table-actions">
                        <button class="btn btn-sm btn-info" onclick="showNotification('Contribution details coming soon', 'info')">
                            <i class="bi bi-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        // Attendance Functions
        async function loadAttendance() {
            const data = await apiCall('/api/chief/attendance');
            const grid = document.getElementById('attendanceGrid');
            if (!grid) return;

            const attendance = data?.attendance || [];
            if (!attendance.length) {
                grid.innerHTML = '<div class="col-12 text-center text-muted">No attendance records yet</div>';
                return;
            }

            grid.innerHTML = attendance.map(record => `
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="mb-1">${record.member_name || 'N/A'}</h6>
                            <p class="mb-1"><strong>Date:</strong> ${record.meeting_date ? new Date(record.meeting_date).toLocaleDateString() : '-'}</p>
                            <p class="mb-0"><strong>Status:</strong> <span class="badge bg-${record.status === 'present' ? 'success' : record.status === 'late' ? 'warning' : 'danger'}">${record.status || 'absent'}</span></p>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function markAttendanceMode() {
            showNotification('Attendance marking mode activated', 'info');
        }

        // Voting Functions
        async function loadVoting() {
            const data = await apiCall('/api/chief/voting');
            if (data) {
                displayVotingHistory(data.votingHistory);
                updateVotingStatus(data.activeVoting);
            }
        }

        function displayVotingHistory(votingHistory) {
            const tbody = document.getElementById('votingHistory');
            tbody.innerHTML = votingHistory.map(voting => `
                <tr>
                    <td>${new Date(voting.created_at).toLocaleDateString()}</td>
                    <td><span class="badge bg-info">${voting.type}</span></td>
                    <td>${voting.topic}</td>
                    <td>${voting.winner || 'Pending'}</td>
                    <td><span class="badge bg-${voting.payment_status === 'paid' ? 'success' : 'warning'}">${voting.payment_status || 'N/A'}</span></td>
                    <td class="table-actions">
                        <button class="btn btn-sm btn-info" onclick="viewVotingDetails(${voting.id})">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-success" onclick="confirmWinner(${voting.id})" ${voting.winner ? 'disabled' : ''}>
                            <i class="bi bi-check"></i> Confirm
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function updateVotingStatus(activeVoting) {
            const statusDiv = document.getElementById('votingStatus');
            if (activeVoting) {
                statusDiv.innerHTML = `
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h6 class="mt-3">Voting in Progress</h6>
                        <p class="text-muted">${activeVoting.topic}</p>
                        <small>Ends: ${new Date(activeVoting.end_time).toLocaleString()}</small>
                    </div>
                `;
            } else {
                statusDiv.innerHTML = `
                    <div class="text-center text-muted">
                        <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
                        <p class="mt-3">No active voting session</p>
                    </div>
                `;
            }
        }

        async function startVotingSession() {
            const form = document.getElementById('startVotingForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            const response = await apiCall('/api/chief/voting', {
                method: 'POST',
                body: JSON.stringify(data)
            });

            if (response) {
                bootstrap.Modal.getInstance(document.getElementById('startVotingModal')).hide();
                form.reset();
                showNotification('Voting session started successfully', 'success');
                loadVoting();
            }
        }

        async function confirmWinner(votingId) {
            const response = await apiCall(`/api/chief/voting/${votingId}/confirm`, {
                method: 'POST'
            });

            if (response) {
                showNotification('Winner confirmed successfully', 'success');
                loadVoting();
            }
        }

        // Fines Functions
        async function loadFines() {
            const data = await apiCall('/api/chief/fines');
            if (data) {
                displayFines(data.fines);
                // Update statistics
                const stats = data.statistics;
                document.getElementById('totalFines').textContent = stats.total || 0;
                document.getElementById('paidFines').textContent = stats.paid || 0;
                document.getElementById('pendingFines').textContent = stats.pending || 0;
                document.getElementById('unpaidFines').textContent = stats.unpaid || 0;
            }
        }

        function displayFines(fines) {
            const tbody = document.getElementById('finesTable');
            tbody.innerHTML = fines.map(fine => `
                <tr>
                    <td>${fine.member_name}</td>
                    <td><span class="badge bg-warning">${fine.fine_type}</span></td>
                    <td>RWF ${fine.amount.toLocaleString()}</td>
                    <td>${new Date(fine.created_at).toLocaleDateString()}</td>
                    <td><span class="badge bg-${fine.status === 'paid' ? 'success' : fine.status === 'pending' ? 'warning' : 'danger'}">${fine.status}</span></td>
                    <td class="table-actions">
                        <button class="btn btn-sm btn-warning" onclick="editFine(${fine.id})">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-success" onclick="markFinePaid(${fine.id})" ${fine.status === 'paid' ? 'disabled' : ''}>
                            <i class="bi bi-check"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        async function createFine() {
            const form = document.getElementById('createFineForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            const response = await apiCall('/api/chief/fines', {
                method: 'POST',
                body: JSON.stringify(data)
            });

            if (response) {
                bootstrap.Modal.getInstance(document.getElementById('createFineModal')).hide();
                form.reset();
                showNotification('Fine created successfully', 'success');
                loadFines();
            }
        }

        // Meetings Functions
        async function loadMeetings() {
            const data = await apiCall('/api/chief/meetings');
            if (data) {
                displayMeetings(data.meetings);
            }
        }

        function displayMeetings(meetings) {
            const meetingsList = document.getElementById('meetingsList');
            meetingsList.innerHTML = meetings.map(meeting => `
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">${meeting.title}</h6>
                            <p class="card-text">
                                <strong>Date:</strong> ${new Date(meeting.meeting_date).toLocaleString()}<br>
                                <strong>Location:</strong> ${meeting.location}<br>
                                <strong>Status:</strong> 
                                <span class="badge bg-${meeting.status === 'completed' ? 'success' : meeting.status === 'ongoing' ? 'primary' : 'warning'}">
                                    ${meeting.status}
                                </span>
                            </p>
                            <div class="mt-3">
                                <button class="btn btn-sm btn-info" onclick="viewMeetingDetails(${meeting.id})">
                                    <i class="bi bi-eye"></i> Details
                                </button>
                                <button class="btn btn-sm btn-primary" onclick="recordMeetingNotes(${meeting.id})" ${meeting.status !== 'completed' ? 'disabled' : ''}>
                                    <i class="bi bi-journal-text"></i> Record Notes
                                </button>
                                <button class="btn btn-sm btn-success" onclick="generateWeeklyReport(${meeting.id})">
                                    <i class="bi bi-file-earmark-text"></i> Weekly Report
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function scheduleMeeting() {
            const form = document.getElementById('scheduleMeetingForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            const response = await apiCall('/api/chief/meetings', {
                method: 'POST',
                body: JSON.stringify(data)
            });

            if (response) {
                bootstrap.Modal.getInstance(document.getElementById('scheduleMeetingModal')).hide();
                form.reset();
                showNotification('Meeting scheduled successfully', 'success');
                loadMeetings();
            }
        }

        // Notifications Functions
        async function loadNotifications() {
            const data = await apiCall('/api/chief/notifications');
            const form = document.getElementById('notificationForm');
            if (form && !form.dataset.boundSubmit) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const payload = {
                        title: document.getElementById('notificationTitle')?.value || '',
                        message: document.getElementById('notificationMessage')?.value || '',
                        type: document.getElementById('notificationType')?.value || 'general'
                    };

                    const response = await apiCall('/api/chief/notifications', {
                        method: 'POST',
                        body: JSON.stringify(payload)
                    });

                    if (response) {
                        form.reset();
                        showNotification('Notification sent successfully', 'success');
                    }
                });
                form.dataset.boundSubmit = 'true';
            }

            if (!data) {
                return;
            }
        }

        async function generateWeeklyReport() {
            const response = await apiCall('/api/chief/reports/weekly', {
                method: 'POST'
            });

            if (response) {
                showNotification('Weekly report generated successfully', 'success');
                // Download or display the report
                window.open(response.reportUrl, '_blank');
            }
        }

        // Enhanced Loans Functions
        async function loadLoans() {
            const data = await apiCall('/api/chief/loans');
            if (data) {
                displayLoans(data.loans);
            }
        }

        function displayLoans(loans) {
            const tbody = document.getElementById('loansTable');
            tbody.innerHTML = loans.map(loan => `
                <tr>
                    <td>${loan.member_name}</td>
                    <td>RWF ${loan.amount.toLocaleString()}</td>
                    <td>${loan.reason}</td>
                    <td><span class="badge bg-${loan.status === 'approved' ? 'success' : loan.status === 'pending' ? 'warning' : 'danger'}">${loan.status}</span></td>
                    <td>RWF ${loan.balance.toLocaleString()}</td>
                    <td class="table-actions">
                        <button class="btn btn-sm btn-info" onclick="viewLoanDetails(${loan.id})">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-success" onclick="recommendLoan(${loan.id})" ${loan.status !== 'pending' ? 'disabled' : ''}>
                            <i class="bi bi-hand-thumbs-up"></i> Recommend
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="rejectLoan(${loan.id})" ${loan.status !== 'pending' ? 'disabled' : ''}>
                            <i class="bi bi-hand-thumbs-down"></i> Reject
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        async function recommendLoan(loanId) {
            const response = await apiCall(`/api/chief/loans/${loanId}/recommend`, {
                method: 'POST'
            });

            if (response) {
                showNotification('Loan recommended to admin successfully', 'success');
                loadLoans();
            }
        }

        async function rejectLoan(loanId) {
            const reason = prompt('Please enter rejection reason:');
            if (!reason) return;

            const response = await apiCall(`/api/chief/loans/${loanId}/reject`, {
                method: 'POST',
                body: JSON.stringify({ reason })
            });

            if (response) {
                showNotification('Loan rejected successfully', 'success');
                loadLoans();
            }
        }

        function displayMembers(members) {
            const grid = document.getElementById('membersGrid');
            grid.innerHTML = members.map(member => `
                <div class="col-md-4">
                    <div class="card member-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="card-title">${member.full_name}</h6>
                                    <p class="text-muted mb-1">Member #${member.member_number}</p>
                                    <p class="text-muted mb-1">${member.phone}</p>
                                </div>
                                <span class="badge ${member.status === 'active' ? 'bg-success' : 'bg-danger'}">${member.status}</span>
                            </div>
                            <div class="mt-3">
                                <button class="btn btn-sm btn-outline-primary me-1" onclick="viewMember(${member.id})">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-warning me-1" onclick="editMember(${member.id})">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="removeMember(${member.id})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Smart Draw Functions
        async function loadDrawData() {
            const data = await apiCall('/api/chief/draw-eligibility');
            if (data) {
                document.getElementById('eligibleCount').textContent = `${data.eligibleCount} eligible members`;
                loadDrawHistory();
            }
        }

        async function startDraw() {
            if (isDrawing) return;
            
            isDrawing = true;
            const wheel = document.getElementById('drawWheel');
            const btn = document.getElementById('startDrawBtn');
            const status = document.getElementById('drawStatus');
            
            wheel.classList.add('spinning');
            btn.disabled = true;
            status.textContent = 'Drawing in progress...';
            
            const response = await apiCall('/api/chief/start-draw', {
                method: 'POST'
            });
            
            wheel.classList.remove('spinning');
            
            if (response) {
                status.textContent = 'Draw Complete!';
                showDrawWinner(response.winner, response.totalAmount);
            } else {
                status.textContent = 'Draw failed. Please try again.';
            }
            
            btn.disabled = false;
            isDrawing = false;
        }

        function addMember() {
            showNotification('Add member feature is in progress', 'info');
            const modal = bootstrap.Modal.getInstance(document.getElementById('addMemberModal'));
            modal?.hide();
        }

        function recordContribution() {
            showNotification('Contribution recording submitted', 'success');
            const modal = bootstrap.Modal.getInstance(document.getElementById('recordContributionModal'));
            modal?.hide();
        }

        function startVoting() {
            startVotingSession();
        }

        function showDrawWinner(winner, amount) {
            document.getElementById('winnerName').textContent = winner.name;
            document.getElementById('winnerNumber').textContent = winner.memberNumber;
            document.getElementById('winnerAmount').textContent = amount.toLocaleString();
            
            const modal = new bootstrap.Modal(document.getElementById('drawWinnerModal'));
            modal.show();
        }

        // Utility Functions
        function refreshData() {
            const activeSection = document.querySelector('.section-content.active').id.replace('-section', '');
            loadData(activeSection);
            showNotification('Data refreshed', 'info');
        }

        function exportReport() {
            showNotification('Generating report...', 'info');
            // Implementation would go here
        }

        function loadRecentActivity() {
            const recentActivity = document.getElementById('recentActivity');
            if (!recentActivity) return;
            recentActivity.innerHTML = `
                <div class="text-muted d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i>
                    <span>No recent activity to display</span>
                </div>
            `;
        }

        function showNotification(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a moment for sessionStorage to be ready
            setTimeout(() => {
                const auth = checkAuth();
                if (auth) {
                    console.log('Page loaded with authenticated user:', auth);
                    loadDashboard();
                }
            }, 100);
            
            // Set today's date for attendance
            document.getElementById('meetingDate').valueAsDate = new Date();
        });
    </script>
</body>
</html>
