<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --sidebar-width: 250px;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
        }
        
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: var(--primary-gradient);
            transition: all 0.3s;
            z-index: 1000;
            overflow-y: auto;
        }
        
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            min-height: 100vh;
        }
        
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 1rem 1.5rem;
            border-radius: 0;
            transition: all 0.3s;
        }
        
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: white;
            background-color: rgba(255, 255, 255, 0.1);
        }
        
        .main-content {
            margin-left: 250px;
            padding: 20px;
            min-height: 100vh;
            transition: margin-left 0.3s;
        }
        
        .navbar-brand {
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
            text-align: center;
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .stat-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: all 0.3s;
            border-left: 4px solid #667eea;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            background: var(--primary-gradient);
        }
        
        .btn-primary {
            background: var(--primary-gradient);
            border: none;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
        }
        
        .section-content {
            display: none;
        }
        
        .section-content.active {
            display: block;
        }
        
        .profile-card {
            background: var(--primary-gradient);
            color: white;
            border-radius: 1rem;
            padding: 2rem;
            text-align: center;
        }
        
        .member-number {
            font-size: 2rem;
            font-weight: bold;
            background: rgba(255, 255, 255, 0.2);
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            display: inline-block;
        }
        
        .draw-number {
            font-size: 3rem;
            font-weight: bold;
            color: #667eea;
            background: white;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .payment-status {
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-size: 0.875rem;
            font-weight: 600;
        }
        
        .status-paid { background-color: #28a745; color: white; }
        .status-pending { background-color: #ffc107; color: black; }
        .status-missed { background-color: #dc3545; color: white; }
        
        .contribution-card {
            transition: all 0.3s;
        }
        
        .contribution-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .navbar-brand {
            color: white !important;
            font-weight: bold;
            font-size: 1.5rem;
        }
        
        .user-info {
            color: white;
            padding: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .modal-header {
            background: var(--primary-gradient);
            color: white;
        }
        
        .form-control:focus,
        .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        
        .loan-card {
            border-left: 4px solid #ffc107;
        }
        
        .notification-item {
            transition: all 0.3s;
        }
        
        .notification-item:hover {
            background-color: #f8f9fa;
        }
        
        .unread {
            border-left: 4px solid #667eea;
            background-color: rgba(102, 126, 234, 0.05);
        }
        
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            
            .sidebar.show {
                transform: translateX(0);
            }
            
            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="p-3">
            <div class="navbar-brand">
                <i class="bi bi-shield-check me-2"></i>
                Ikibina Guardian
            </div>
        </div>
        
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link active" href="#" onclick="showSection(event, 'dashboard')">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'profile')">
                    <i class="bi bi-person me-2"></i> My Profile
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'contributions')">
                    <i class="bi bi-cash-stack me-2"></i> My Contributions
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'attendance')">
                    <i class="bi bi-calendar-check me-2"></i> Attendance
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'draw')">
                    <i class="bi bi-dice-5 me-2"></i> Smart Draw
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'voting')">
                    <i class="bi bi-balloon-heart me-2"></i> Voting
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'loans')">
                    <i class="bi bi-bank me-2"></i> Loans
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'fines')">
                    <i class="bi bi-cash-coin me-2"></i> Fines
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#" onclick="showSection(event, 'notifications')">
                    <i class="bi bi-bell me-2"></i> Notifications
                </a>
            </li>
        </ul>
        
        <div class="user-info">
            <div class="d-flex align-items-center">
                <i class="bi bi-person-circle me-2"></i>
                <div>
                    <div class="fw-bold" id="sidebarUserName">Loading...</div>
                    <small>Member</small>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-light mt-2 w-100" onclick="logout()">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Member Dashboard</h1>
            <div>
                <button class="btn btn-outline-secondary me-2" onclick="refreshData()">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button class="btn btn-primary" onclick="downloadReceipts()">
                    <i class="bi bi-download"></i> Download Receipts
                </button>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" class="section-content active">
            <!-- Profile Card -->
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="profile-card">
                        <i class="bi bi-person-circle" style="font-size: 4rem;"></i>
                        <h4 id="profileName">Loading...</h4>
                        <p id="profileEmail">Loading...</p>
                        <div class="member-number mt-3">
                            Member #<span id="memberNumber">---</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1" id="groupName">Loading...</h5>
                                        <p class="text-muted mb-0">My Group</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-people"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1" id="contributionAmount">RWF 0</h5>
                                        <p class="text-muted mb-0">Contribution Amount</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1" id="paymentStatus">-</h5>
                                        <p class="text-muted mb-0">Payment Status</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-check-circle"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1" id="nextDrawDate">-</h5>
                                        <p class="text-muted mb-0">Next Draw Date</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-calendar-event"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalContributions">0</h3>
                                <p class="text-muted mb-0">Total Contributions</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-cash"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="missedPayments">0</h3>
                                <p class="text-muted mb-0">Missed Payments</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-x-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="attendanceRate">0%</h3>
                                <p class="text-muted mb-0">Attendance Rate</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-graph-up"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="loanBalance">0</h3>
                                <p class="text-muted mb-0">Loan Balance</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-bank"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Activity</h5>
                </div>
                <div class="card-body">
                    <div id="recentActivity">
                        <!-- Recent activities will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Profile Section -->
        <div id="profile-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">My Profile</h5>
                </div>
                <div class="card-body">
                    <form id="profileForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="fullName" class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="fullName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="memberNumber" class="form-label">Member Number</label>
                                <input type="text" class="form-control" id="memberNumberField" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email">
                            </div>
                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="tel" class="form-control" id="phone">
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">Update Profile</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Contributions Section -->
        <div id="contributions-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">My Contribution History</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-4" id="contributionsGrid">
                        <!-- Contributions will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Attendance Section -->
        <div id="attendance-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Attendance History</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                                <tr>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Fine Amount</th>
                                </tr>

                                
                            </thead>
                            <tbody id="attendanceTable">
                                <!-- Attendance will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Smart Draw Section -->
        <div id="draw-section" class="section-content">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card text-center">
                        <div class="card-header">
                            <h5 class="mb-0">My Draw Number</h5>
                        </div>
                        <div class="card-body">
                            <div class="draw-number" id="myDrawNumber">
                                <span id="drawNumberValue">---</span>
                            </div>
                            <h5 class="mt-3">Next Draw Date</h5>
                            <p class="text-muted" id="drawNextDate">-</p>
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i>
                                <strong>Eligibility:</strong> <span id="eligibilityStatus">Checking...</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Draw History</h5>
                        </div>
                        <div class="card-body">
                            <div id="drawHistory">
                                <!-- Draw history will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loans Section -->
        <div id="loans-section" class="section-content">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">My Loans</h5>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#applyLoanModal">
                        <i class="bi bi-plus-circle"></i> Apply for Loan
                    </button>
                </div>
                <div class="card-body">
                    <div id="loansList">
                        <!-- Loans will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Voting Section -->
        <div id="voting-section" class="section-content">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Active Voting Session</h5>
                        </div>
                        <div class="card-body">
                            <div id="activeVoting">
                                <div class="text-center text-muted">
                                    <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
                                    <p class="mt-3">No active voting session</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">My Voting History</h5>
                        </div>
                        <div class="card-body">
                            <div id="votingHistory">
                                <!-- Voting history will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fines Section -->
        <div id="fines-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">My Fines</h5>
                </div>
                <div class="card-body">
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="totalFines">0</h3>
                                        <p class="text-muted mb-0">Total Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-cash-coin"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="paidFines">0</h3>
                                        <p class="text-muted mb-0">Paid Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-check-circle"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h3 class="mb-1" id="unpaidFines">0</h3>
                                        <p class="text-muted mb-0">Unpaid Fines</p>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-x-circle"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Reason</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="finesTable">
                                <!-- Fines will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Section -->
        <div id="notifications-section" class="section-content">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">My Notifications</h5>
                </div>
                <div class="card-body">
                    <div id="notificationsList">
                        <!-- Notifications will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Apply Loan Modal -->
    <div class="modal fade" id="applyLoanModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Apply for Loan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="loanApplicationForm">
                        <div class="mb-3">
                            <label for="loanAmount" class="form-label">Amount (RWF)</label>
                            <input type="number" class="form-control" id="loanAmount" required>
                        </div>
                        <div class="mb-3">
                            <label for="loanReason" class="form-label">Reason</label>
                            <textarea class="form-control" id="loanReason" rows="3" required></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitLoanApplication(event)">Submit Application</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentData = {};

        // Authentication check
        let authChecked = false;
        function checkAuth() {
            if (authChecked) {
                console.log('Auth already checked, preventing redirect loop');
                return JSON.parse(sessionStorage.getItem('user') || '{}');
            }
            
            const user = sessionStorage.getItem('user');
            console.log('Checking auth, user:', user);
            if (!user) {
                console.log('No user found, redirecting to login');
                window.location.href = '/login';
                return false;
            }
            try {
                const parsedUser = JSON.parse(user);
                console.log('User authenticated:', parsedUser);
                authChecked = true;
                return parsedUser;
            } catch (error) {
                console.error('Error parsing user data:', error);
                sessionStorage.removeItem('user');
                window.location.href = '/login';
                return false;
            }
        }

        async function apiCall(url, options = {}) {
            const defaultOptions = {
                headers: {
                    'Content-Type': 'application/json'
                }
            };
            
            const finalOptions = {
                ...defaultOptions,
                ...options,
                headers: {
                    ...defaultOptions.headers,
                    ...options.headers
                }
            };
            
            try {
                const response = await fetch(url, finalOptions);
                
                // Don't clear sessionStorage on 401, let's auth check handle it
                if (!response.ok) {
                    console.error('API call failed:', response.status, response.statusText);
                    return null;
                }
                
                return await response.json();
            } catch (error) {
                console.error('API call error:', error);
                return null;
            }
        }

        function logout() {
            sessionStorage.removeItem('user');
            window.location.href = '/login';
        }

        // Section Management
        function showSection(evt, section) {
            if (evt && typeof evt.preventDefault === 'function') {
                evt.preventDefault();
            }

            const sections = ['dashboard', 'profile', 'contributions', 'attendance', 'draw', 'voting', 'loans', 'fines', 'notifications'];
            sections.forEach(s => {
                const element = document.getElementById(`${s}-section`);
                if (element) {
                    element.classList.toggle('active', s === section);
                }
            });

            const navLinks = document.querySelectorAll('.sidebar .nav-link');
            navLinks.forEach(link => link.classList.remove('active'));
            const clickedLink = evt?.target?.closest?.('.nav-link');
            if (clickedLink) {
                clickedLink.classList.add('active');
            }

            loadData(section);
        }

        async function loadData(section) {
            switch(section) {
                case 'dashboard':
                    await loadDashboard();
                    break;
                case 'profile':
                    await loadProfile();
                    break;
                case 'contributions':
                    await loadContributions();
                    break;
                case 'attendance':
                    await loadAttendance();
                    break;
                case 'draw':
                    await loadDrawInfo();
                    break;
                case 'voting':
                    await loadVoting();
                    break;
                case 'loans':
                    await loadLoans();
                    break;
                case 'fines':
                    await loadFines();
                    break;
                case 'notifications':
                    await loadNotifications();
                    break;
            }
        }

        // Dashboard Functions
        async function loadDashboard() {
            const data = await apiCall('/api/member/profile');
            if (data) {
                const user = data.user;
                const membership = data.membership;
                
                // Update profile info
                document.getElementById('sidebarUserName').textContent = user.full_name;
                document.getElementById('profileName').textContent = user.full_name;
                document.getElementById('profileEmail').textContent = user.email;
                document.getElementById('memberNumber').textContent = membership?.member_number || 'N/A';
                
                // Update group info
                if (membership) {
                    document.getElementById('groupName').textContent = membership.group_name;
                    document.getElementById('contributionAmount').textContent = `RWF ${membership.contribution_amount?.toLocaleString() || 0}`;
                    document.getElementById('nextDrawDate').textContent = membership.draw_day || 'Not set';
                }
                
                // Load contributions for stats
                const contributions = await apiCall('/api/member/contributions');
                if (contributions) {
                    const total = contributions.contributions.reduce((sum, c) => sum + c.amount, 0);
                    const missed = contributions.contributions.filter(c => c.payment_status === 'missed').length;
                    
                    document.getElementById('totalContributions').textContent = total.toLocaleString();
                    document.getElementById('missedPayments').textContent = missed;
                }
                
                loadRecentActivity();
            }
        }

        // Profile Functions
        async function loadProfile() {
            const data = await apiCall('/api/member/profile');
            if (data) {
                const user = data.user;
                const membership = data.membership;
                
                document.getElementById('fullName').value = user.full_name;
                document.getElementById('email').value = user.email || '';
                document.getElementById('phone').value = user.phone || '';
                document.getElementById('memberNumberField').value = membership?.member_number || 'N/A';
            }
        }

        // Contributions Functions
        async function loadContributions() {
            const data = await apiCall('/api/member/contributions');
            if (data) {
                displayContributions(data.contributions);
            }
        }

        function displayContributions(contributions) {
            const grid = document.getElementById('contributionsGrid');
            grid.innerHTML = contributions.map(contribution => `
                <div class="col-md-4">
                    <div class="card contribution-card">
                        <div class="card-body">
                            <h6 class="card-title">${contribution.payment_cycle}</h6>
                            <p class="card-text">
                                <strong>Amount:</strong> RWF ${contribution.amount.toLocaleString()}<br>
                                <strong>Date:</strong> ${new Date(contribution.paid_at).toLocaleDateString()}<br>
                                <strong>Status:</strong> 
                                <span class="payment-status status-${contribution.payment_status}">
                                    ${contribution.payment_status}
                                </span>
                            </p>
                            ${contribution.payment_status === 'paid' ? `
                                <button class="btn btn-sm btn-outline-primary" onclick="downloadReceipt(${contribution.id})">
                                    <i class="bi bi-download"></i> Receipt
                                </button>
                            ` : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Draw Functions
        async function loadDrawInfo() {
            const data = await apiCall('/api/member/profile');
            if (data && data.membership) {
                document.getElementById('drawNumberValue').textContent = data.membership.member_number || 'N/A';
                document.getElementById('drawNextDate').textContent = data.membership.draw_day || 'Not set';
                document.getElementById('eligibilityStatus').textContent = 'Eligible for next draw';
            }
        }

        // Voting Functions
        async function loadVoting() {
            const data = await apiCall('/api/member/voting');
            if (data) {
                displayActiveVoting(data.activeVoting);
                displayVotingHistory(data.votingHistory);
            }
        }

        function displayActiveVoting(activeVoting) {
            const activeVotingDiv = document.getElementById('activeVoting');
            if (activeVoting) {
                activeVotingDiv.innerHTML = `
                    <div class="alert alert-info">
                        <h6>Active Voting Session</h6>
                        <p><strong>Topic:</strong> ${activeVoting.topic}</p>
                        <p><strong>Description:</strong> ${activeVoting.description}</p>
                        <p><strong>Ends:</strong> ${new Date(activeVoting.end_time).toLocaleString()}</p>
                        <div class="mt-3">
                            <button class="btn btn-primary" onclick="voteInVoting()">
                                <i class="bi bi-balloon-heart"></i> Cast Vote
                            </button>
                        </div>
                    </div>
                `;
            } else {
                activeVotingDiv.innerHTML = `
                    <div class="text-center text-muted">
                        <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
                        <p class="mt-3">No active voting session</p>
                    </div>
                `;
            }
        }

        function displayVotingHistory(votingHistory) {
            const historyDiv = document.getElementById('votingHistory');
            historyDiv.innerHTML = votingHistory.map(voting => `
                <div class="card mb-2">
                    <div class="card-body">
                        <h6>${voting.topic}</h6>
                        <p class="text-muted">${new Date(voting.created_at).toLocaleDateString()}</p>
                        <p><strong>Winner:</strong> ${voting.winner || 'Pending'}</p>
                        <p><strong>Your Vote:</strong> ${voting.my_vote || 'Did not vote'}</p>
                    </div>
                </div>
            `).join('');
        }

        async function voteInVoting() {
            const voteChoice = prompt('Enter your vote choice:');
            if (!voteChoice) return;

            const response = await apiCall('/api/member/voting/vote', {
                method: 'POST',
                body: JSON.stringify({ vote: voteChoice })
            });

            if (response) {
                showNotification('Vote cast successfully', 'success');
                loadVoting();
            }
        }

        // Fines Functions
        async function loadFines() {
            const data = await apiCall('/api/member/fines');
            if (data) {
                displayFines(data.fines);
                // Update statistics
                const stats = data.statistics;
                document.getElementById('totalFines').textContent = stats.total || 0;
                document.getElementById('paidFines').textContent = stats.paid || 0;
                document.getElementById('unpaidFines').textContent = stats.unpaid || 0;
            }
        }

        function displayFines(fines) {
            const tbody = document.getElementById('finesTable');
            tbody.innerHTML = fines.map(fine => `
                <tr>
                    <td>${new Date(fine.created_at).toLocaleDateString()}</td>
                    <td><span class="badge bg-warning">${fine.fine_type}</span></td>
                    <td>RWF ${fine.amount.toLocaleString()}</td>
                    <td>${fine.reason}</td>
                    <td><span class="badge bg-${fine.status === 'paid' ? 'success' : 'danger'}">${fine.status}</span></td>
                    <td class="table-actions">
                        ${fine.status === 'unpaid' ? `
                            <button class="btn btn-sm btn-success" onclick="payFine(${fine.id})">
                                <i class="bi bi-credit-card"></i> Pay
                            </button>
                        ` : `
                            <button class="btn btn-sm btn-info" onclick="viewFineDetails(${fine.id})">
                                <i class="bi bi-eye"></i> View
                            </button>
                        `}
                    </td>
                </tr>
            `).join('');
        }

        async function payFine(fineId) {
            const confirmPayment = confirm('Are you sure you want to pay this fine?');
            if (!confirmPayment) return;

            const response = await apiCall(`/api/member/fines/${fineId}/pay`, {
                method: 'POST'
            });

            if (response) {
                showNotification('Fine paid successfully', 'success');
                loadFines();
                // Open receipt
                window.open(response.receiptUrl, '_blank');
            }
        }

        // Enhanced Notifications Functions
        async function loadNotifications() {
            const data = await apiCall('/api/member/notifications');
            if (data) {
                displayNotifications(data.notifications);
            }
        }

        function displayNotifications(notifications) {
            const notificationsList = document.getElementById('notificationsList');
            notificationsList.innerHTML = notifications.map(notif => `
                <div class="notification-item ${notif.read ? '' : 'unread'} p-3 border-bottom">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="mb-1">${notif.title}</h6>
                            <p class="text-muted mb-1">${notif.message}</p>
                            <small class="text-muted">${new Date(notif.created_at).toLocaleString()}</small>
                        </div>
                        <div class="ms-3">
                            <span class="badge bg-${notif.type === 'meeting' ? 'info' : notif.type === 'payment' ? 'warning' : notif.type === 'draw' ? 'success' : 'primary'}">
                                ${notif.type}
                            </span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Enhanced Loan Functions
        async function loadLoans() {
            const data = await apiCall('/api/member/loans');
            if (data) {
                displayLoans(data.loans);
            }
        }

        function displayLoans(loans) {
            const list = document.getElementById('loansList');
            list.innerHTML = loans.map(loan => `
                <div class="card loan-card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="card-title">RWF ${loan.amount.toLocaleString()}</h6>
                                <p class="card-text">
                                    <strong>Reason:</strong> ${loan.reason}<br>
                                    <strong>Status:</strong> 
                                    <span class="badge bg-${loan.status === 'approved' ? 'success' : loan.status === 'pending' ? 'warning' : 'danger'}">
                                        ${loan.status}
                                    </span><br>
                                    <strong>Balance:</strong> RWF ${loan.balance.toLocaleString()}<br>
                                    <strong>Next Payment:</strong> ${loan.next_payment_date ? new Date(loan.next_payment_date).toLocaleDateString() : 'N/A'}
                                </p>
                            </div>
                            <div>
                                <small class="text-muted">
                                    Applied: ${new Date(loan.created_at).toLocaleDateString()}
                                </small>
                                <div class="mt-2">
                                    ${loan.status === 'approved' && loan.balance > 0 ? `
                                        <button class="btn btn-sm btn-success" onclick="makeLoanPayment(${loan.id})">
                                            <i class="bi bi-credit-card"></i> Pay
                                        </button>
                                    ` : ''}
                                    <button class="btn btn-sm btn-info" onclick="viewLoanSchedule(${loan.id})">
                                        <i class="bi bi-calendar"></i> Schedule
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function makeLoanPayment(loanId) {
            const amount = prompt('Enter payment amount (RWF):');
            if (!amount || isNaN(amount)) return;

            const response = await apiCall(`/api/member/loans/${loanId}/pay`, {
                method: 'POST',
                body: JSON.stringify({ amount: parseFloat(amount) })
            });

            if (response) {
                showNotification('Payment processed successfully', 'success');
                loadLoans();
                // Open receipt
                window.open(response.receiptUrl, '_blank');
            }
        }

        async function viewLoanSchedule(loanId) {
            const data = await apiCall(`/api/member/loans/${loanId}/schedule`);
            if (data) {
                // Display payment schedule in modal
                alert(`Payment Schedule:\n${data.schedule.map(s => `${s.date}: RWF ${s.amount}`).join('\n')}`);
            }
        }

        // Loans Functions
        async function loadLoans() {
            const data = await apiCall('/api/member/loans');
            if (data) {
                displayLoans(data.loans);
            }
        }

        function displayLoans(loans) {
            const list = document.getElementById('loansList');
            list.innerHTML = loans.map(loan => `
                <div class="card loan-card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="card-title">RWF ${loan.amount.toLocaleString()}</h6>
                                <p class="card-text">
                                    <strong>Reason:</strong> ${loan.reason}<br>
                                    <strong>Status:</strong> 
                                    <span class="badge bg-${loan.status === 'approved' ? 'success' : loan.status === 'pending' ? 'warning' : 'danger'}">
                                        ${loan.status}
                                    </span><br>
                                    <strong>Balance:</strong> RWF ${loan.balance.toLocaleString()}
                                </p>
                            </div>
                            <div>
                                <small class="text-muted">
                                    Applied: ${new Date(loan.created_at).toLocaleDateString()}
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function submitLoanApplication(event) {
            event.preventDefault();
            const amount = document.getElementById('loanAmount').value;
            const reason = document.getElementById('loanReason').value;
            
            if (!amount || !reason) {
                alert('Please fill in all fields');
                return;
            }
            
            // Simulate successful loan application
            const newLoan = {
                id: Date.now(),
                amount: parseFloat(amount),
                reason: reason,
                status: 'pending',
                created_at: new Date().toISOString(),
                balance: parseFloat(amount)
            };
            
            bootstrap.Modal.getInstance(document.getElementById('applyLoanModal')).hide();
            document.getElementById('loanApplicationForm').reset();
            showNotification('Loan application submitted successfully', 'success');
            
            // Add to current loans list
            const currentLoans = currentData.loans || [];
            currentLoans.push(newLoan);
            currentData.loans = currentLoans;
            
            displayLoans(currentLoans);
        }

        // Notifications Functions
        async function loadNotifications() {
            const data = await apiCall('/api/member/notifications');
            if (data) {
                displayNotifications(data.notifications);
            }
        }

        function displayNotifications(notifications) {
            const list = document.getElementById('notificationsList');
            list.innerHTML = notifications.map(notification => `
                <div class="notification-item p-3 border-bottom ${!notification.read ? 'unread' : ''}">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">${notification.title}</h6>
                            <p class="mb-1">${notification.message}</p>
                            <small class="text-muted">${new Date(notification.created_at).toLocaleDateString()}</small>
                        </div>
                        ${!notification.read ? '<span class="badge bg-primary">New</span>' : ''}
                    </div>
                </div>
            `).join('');
        }

        // Utility Functions
        function refreshData() {
            const activeSection = document.querySelector('.section-content.active').id.replace('-section', '');
            loadData(activeSection);
            showNotification('Data refreshed', 'info');
        }

        function downloadReceipt(contributionId) {
            showNotification('Downloading receipt...', 'info');
            // Implementation would go here
        }

        function downloadReceipts() {
            showNotification('Preparing all receipts...', 'info');
            // Implementation would go here
        }

        function showNotification(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        function loadRecentActivity() {
            // Placeholder for recent activity
            document.getElementById('recentActivity').innerHTML = `
                <div class="d-flex align-items-center text-muted">
                    <i class="bi bi-info-circle me-2"></i>
                    <span>No recent activity to display</span>
                </div>
            `;
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a moment for sessionStorage to be ready
            setTimeout(() => {
                const auth = checkAuth();
                if (auth) {
                    console.log('Page loaded with authenticated user:', auth);
                    // Update user name in sidebar
                    document.getElementById('sidebarUserName').textContent = auth.full_name;
                    showSection(null, 'dashboard');
                }
            }, 100);
        });
    </script>
</body>
</html>
