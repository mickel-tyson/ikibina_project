        async function createChief() {
            const form = document.getElementById('createChiefForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            
            // Validate passwords match
            if (data.password !== data.confirm_password) {
                alert('Passwords do not match');
                return;
            }
            
            // Validate group selection
            if (!data.group_id) {
                alert('Please select a group for the chief');
                return;
            }
            
            try {
                // First create the chief user
                const chiefData = {
                    full_name: data.full_name,
                    email: data.email,
                    phone: data.phone,
                    password: data.password,
                    role: 'chief'
                };
                
                const response = await apiCall('/api/admin/users', {
                    method: 'POST',
                    body: JSON.stringify(chiefData)
                });
                
                if (response && response.user) {
                    // Then assign the chief to the selected group
                    const assignResponse = await apiCall('/api/admin/groups/' + data.group_id, {
                        method: 'PUT',
                        body: JSON.stringify({
                            chief_id: response.user.id
                        })
                    });
                    
                    if (assignResponse && assignResponse.message) {
                        alert(`Chief created and assigned to group successfully!`);
                        bootstrap.Modal.getInstance(document.querySelector('.modal')).hide();
                        loadChiefs(); // Refresh chiefs list
                        loadGroups(); // Refresh groups list to show chief assignment
                    } else {
                        alert('Chief created but failed to assign to group');
                    }
                } else {
                    alert('Error creating chief');
                }
            } catch (error) {
                console.error('Create chief error:', error);
                alert('Error creating chief: ' + (error.message || 'Unknown error'));
            }
        }

