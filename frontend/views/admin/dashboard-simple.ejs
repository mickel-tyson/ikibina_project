<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: white;
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }
        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #2c3e50 0%, #34495e 100%);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            box-shadow: 2px 0 15px rgba(0, 0, 0, 0.3);
            overflow-y: auto;
        }
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 30px;
            min-height: 100vh;
            background: white;
        }
        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            display: flex;
            align-items: center;
            padding: 25px 20px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 10px;
            background: rgba(255, 255, 255, 0.05);
        }
        .navbar-brand i {
            font-size: 1.8rem;
            margin-right: 12px;
            color: #3498db;
        }
        .nav-section {
            padding: 15px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .nav-section-title {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 0 20px;
            margin-bottom: 10px;
        }
        .list-group-item {
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.8);
            padding: 15px 20px;
            margin: 2px 10px;
            border-radius: 10px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            font-weight: 500;
        }
        .list-group-item i {
            margin-right: 12px;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }
        .list-group-item:hover {
            background: rgba(52, 152, 219, 0.2);
            color: #fff;
            transform: translateX(5px);
        }
        .list-group-item.active {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.3);
            transform: translateX(5px);
        }
        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
            margin-bottom: 25px;
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
            border-radius: 20px 20px 0 0 !important;
            border: none;
            font-weight: 600;
            padding: 20px 25px;
            font-size: 1.1rem;
        }
        .stat-card {
            background: white;
            color: #2c3e50;
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid #e1e8ed;
        }
        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        }
        .stat-card h3 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #3498db;
        }
        .stat-card p {
            font-size: 1rem;
            margin: 0;
            color: #7f8c8d;
        }
        .btn-primary {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            border: none;
            border-radius: 25px;
            padding: 12px 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.3);
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(52, 152, 219, 0.4);
            background: linear-gradient(135deg, #2980b9 0%, #3498db 100%);
        }
        .table {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }
        .table th {
            background: #f8f9fa;
            border: none;
            font-weight: 600;
            color: #2c3e50;
            padding: 15px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .table td {
            padding: 15px;
            vertical-align: middle;
            border-top: 1px solid #f1f3f4;
        }
        .table-hover tbody tr:hover {
            background: rgba(52, 152, 219, 0.05);
        }
        .user-info {
            background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.2) 100%);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 20px;
            margin: 20px;
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .section-content {
            animation: fadeInUp 0.6s ease;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .badge {
            font-size: 0.8em;
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 500;
        }
        .modal-content {
            border: none;
            border-radius: 20px;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.3);
        }
        .modal-header {
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
            border-radius: 20px 20px 0 0;
            border: none;
            padding: 20px 25px;
        }
        .form-control, .form-select {
            border-radius: 10px;
            border: 1px solid #e1e8ed;
            padding: 12px 15px;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .form-control:focus, .form-select:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
        }
        .form-label {
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 8px;
        }
        .btn-sm {
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 500;
        }
        .btn-outline-primary {
            border-color: #3498db;
            color: #3498db;
        }
        .btn-outline-primary:hover {
            background: #3498db;
            border-color: #3498db;
        }
        .card.border-primary {
            border: 2px solid #3498db;
            border-radius: 15px;
        }
        .card.border-success {
            border: 2px solid #27ae60;
            border-radius: 15px;
        }
        .card.border-warning {
            border: 2px solid #f39c12;
            border-radius: 15px;
        }
        .card.border-info {
            border: 2px solid #8e44ad;
            border-radius: 15px;
        }
        .card-title {
            color: #2c3e50;
            font-weight: 600;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <nav class="sidebar">
            <div class="navbar-brand">
                <i class="bi bi-shield-check"></i>
                Ikibina Guardian
            </div>
            
            <ul class="nav flex-column">
                <div class="nav-section">
                    <div class="nav-section-title">Overview</div>
                    <a href="#" class="list-group-item list-group-item-action active" onclick="showSection('dashboard', event)">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </div>
                
                <div class="nav-section">
                    <div class="nav-section-title">Management</div>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('groups', event)">
                        <i class="bi bi-people"></i> Groups
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('chiefs', event)">
                        <i class="bi bi-person-badge"></i> Chiefs
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('members', event)">
                        <i class="bi bi-person-plus"></i> Members
                    </a>
                </div>
                
                <div class="nav-section">
                    <div class="nav-section-title">Financial</div>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('contributions', event)">
                        <i class="bi bi-cash"></i> Contributions
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('loans', event)">
                        <i class="bi bi-bank"></i> Loans
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('fines', event)">
                        <i class="bi bi-exclamation-triangle"></i> Fines
                    </a>
                </div>
                
                <div class="nav-section">
                    <div class="nav-section-title">Activities</div>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('meetings', event)">
                        <i class="bi bi-calendar"></i> Meetings
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('attendance', event)">
                        <i class="bi bi-calendar-check"></i> Attendance
                    </a>
                </div>
                
                <div class="nav-section">
                    <div class="nav-section-title">System</div>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('reports', event)">
                        <i class="bi bi-file-earmark-text"></i> Reports
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" onclick="showSection('settings', event)">
                        <i class="bi bi-gear"></i> Settings
                    </a>
                </div>
            </ul>
            
            <div class="user-info">
                <div class="d-flex align-items-center">
                    <i class="bi bi-person-circle me-3" style="font-size: 2rem;"></i>
                    <div>
                        <div class="fw-bold"><%= user.full_name %></div>
                        <small>System Administrator</small>
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-sm btn-outline-light w-100" onclick="logout()">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </button>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Admin Dashboard</h1>
                <div>
                    <button class="btn btn-outline-secondary" onclick="refreshData()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
            </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" class="section-content active">
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalGroups">0</h3>
                                <p class="text-muted mb-0">Total Groups</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-people"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="activeGroups">0</h3>
                                <p class="text-muted mb-0">Active Groups</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalChiefs">0</h3>
                                <p class="text-muted mb-0">Total Chiefs</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-person-badge"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalMembers">0</h3>
                                <p class="text-muted mb-0">Total Members</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalContributions">0</h3>
                                <p class="text-muted mb-0">Total Contributions</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="pendingPayments">0</h3>
                                <p class="text-muted mb-0">Pending Payments</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-clock"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="totalLoans">0</h3>
                                <p class="text-muted mb-0">Total Loans</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-bank"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-1" id="defaulters">0</h3>
                                <p class="text-muted mb-0">Loan Defaulters</p>
                            </div>
                            <div class="stat-icon">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">System Status</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle me-2"></i>
                        <strong>System Status:</strong> All systems operational
                    </div>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Last Update:</strong> <span id="lastUpdate">Just now</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Groups Section -->
        <div id="groups-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Groups Management</h5>
                    <button class="btn btn-primary" onclick="showCreateGroupModal()">
                        <i class="bi bi-plus"></i> Create Group
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Group Name</th>
                                    <th>Group Code</th>
                                    <th>District</th>
                                    <th>Chief</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="groupsTable">
                                <!-- Groups will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chiefs Section -->
        <div id="chiefs-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Chiefs Management</h5>
                    <button class="btn btn-primary" onclick="showCreateChiefModal()">
                        <i class="bi bi-plus"></i> Register Chief
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Group</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="chiefsTable">
                                <!-- Chiefs will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Members Section -->
        <div id="members-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Members Management</h5>
                    <button class="btn btn-primary" onclick="showCreateMemberModal()">
                        <i class="bi bi-plus"></i> Register Member
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Group</th>
                                    <th>Member Number</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="membersTable">
                                <!-- Members will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reports Section -->
        <div id="reports-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Reports</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="bi bi-file-earmark-text fs-1 text-primary"></i>
                                    <h6 class="mt-2">Weekly Reports</h6>
                                    <button class="btn btn-sm btn-outline-primary">Generate</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="bi bi-file-earmark-bar-graph fs-1 text-success"></i>
                                    <h6 class="mt-2">Monthly Reports</h6>
                                    <button class="btn btn-sm btn-outline-success">Generate</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="bi bi-file-earmark-ppt fs-1 text-warning"></i>
                                    <h6 class="mt-2">Financial Reports</h6>
                                    <button class="btn btn-sm btn-outline-warning">Generate</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="bi bi-file-earmark-check fs-1 text-info"></i>
                                    <h6 class="mt-2">Activity Reports</h6>
                                    <button class="btn btn-sm btn-outline-info">Generate</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                            <button class="btn btn-primary" onclick="generateReport('custom')">
                                <i class="bi bi-download"></i> Download Custom Report
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contributions Management Section -->
        <div id="contributions-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Contributions by Group</h5>
                    <select class="form-select" style="width: 200px;" id="groupFilterContributions" onchange="loadAdminContributions()">
                        <option value="">All Groups</option>
                    </select>
                </div>
                <div class="card-body">
                    <div id="groupContributionStats" class="row mb-4">
                        <!-- Group statistics will be loaded here -->
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Group</th>
                                    <th>Amount</th>
                                    <th>Payment Cycle</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Receipt</th>
                                </tr>
                            </thead>
                            <tbody id="adminContributionsTable">
                                <!-- Contributions will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loans Management Section -->
        <div id="loans-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Loans by Group</h5>
                    <select class="form-select" style="width: 200px;" id="groupFilterLoans" onchange="loadAdminLoans()">
                        <option value="">All Groups</option>
                    </select>
                </div>
                <div class="card-body">
                    <div id="groupLoanStats" class="row mb-4">
                        <!-- Group statistics will be loaded here -->
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Group</th>
                                    <th>Amount</th>
                                    <th>Purpose</th>
                                    <th>Interest Rate</th>
                                    <th>Term</th>
                                    <th>Status</th>
                                    <th>Applied Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="adminLoansTable">
                                <!-- Loans will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Meetings Management Section -->
        <div id="meetings-section" class="section-content" style="display: none;">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Meetings by Group</h5>
                    <select class="form-select" style="width: 200px;" id="groupFilterMeetings" onchange="loadAdminMeetings()">
                        <option value="">All Groups</option>
                    </select>
                </div>
                <div class="card-body">
                    <div id="groupMeetingStats" class="row mb-4">
                        <!-- Group statistics will be loaded here -->
                    </div>
                    <div class="table-responsive">
