                document.getElementById('adminContributionsTable').innerHTML = '<tr><td colspan="8">No contributions found</td></tr>';
            }
        }

        async function loadGroupContributionStats(contributions) {
            const statsDiv = document.getElementById('groupContributionStats');
            const groupStats = {};
            
            contributions.forEach(c => {
                if (!groupStats[c.group_name]) {
                    groupStats[c.group_name] = { count: 0, total: 0, paid: 0 };
                }
                groupStats[c.group_name].count++;
                groupStats[c.group_name].total += c.amount;
                if (c.payment_status === 'paid') {
                    groupStats[c.group_name].paid += c.amount;
                }
            });
            
            statsDiv.innerHTML = Object.entries(groupStats).map(([groupName, stats]) => `
                <div class="col-md-4 mb-3">
                    <div class="card border-primary">
                        <div class="card-body">
                            <h6 class="card-title">${groupName}</h6>
                            <div class="d-flex justify-content-between">
                                <small>Contributions:</small>
                                <strong>${stats.count}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Total:</small>
                                <strong>RWF ${stats.total.toLocaleString()}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Paid:</small>
                                <strong>RWF ${stats.paid.toLocaleString()}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function loadAdminLoans() {
            try {
                await loadGroupFilters();
                
                const groupId = document.getElementById('groupFilterLoans').value;
                const url = groupId ? `/api/admin/loans?group_id=${groupId}` : '/api/admin/loans';
                const data = await apiCall(url);
                
                if (data && data.loans) {
                    const tbody = document.getElementById('adminLoansTable');
                    tbody.innerHTML = data.loans.map(loan => `
                        <tr>
                            <td>${loan.full_name}</td>
                            <td>${loan.group_name}</td>
                            <td>RWF ${loan.amount.toLocaleString()}</td>
                            <td>${loan.purpose || 'N/A'}</td>
                            <td>${loan.interest_rate}%</td>
                            <td>${loan.term_months} months</td>
                            <td><span class="badge ${getAdminStatusColor(loan.status)}">${loan.status}</span></td>
                            <td>${new Date(loan.applied_at).toLocaleDateString()}</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" onclick="viewLoanDetails(${loan.id})">View Details</button>
                            </td>
                        </tr>
                    `).join('');
                    
                    loadGroupLoanStats(data.loans);
                }
            } catch (error) {
                console.error('Error loading admin loans:', error);
                document.getElementById('adminLoansTable').innerHTML = '<tr><td colspan="9">No loans found</td></tr>';
            }
        }

        async function loadGroupLoanStats(loans) {
            const statsDiv = document.getElementById('groupLoanStats');
            const groupStats = {};
            
            loans.forEach(loan => {
                if (!groupStats[loan.group_name]) {
                    groupStats[loan.group_name] = { count: 0, total: 0, approved: 0, pending: 0 };
                }
                groupStats[loan.group_name].count++;
                groupStats[loan.group_name].total += loan.amount;
                if (loan.status === 'approved') {
                    groupStats[loan.group_name].approved += loan.amount;
                } else if (loan.status === 'pending') {
                    groupStats[loan.group_name].pending += loan.amount;
                }
            });
            
            statsDiv.innerHTML = Object.entries(groupStats).map(([groupName, stats]) => `
                <div class="col-md-4 mb-3">
                    <div class="card border-success">
                        <div class="card-body">
                            <h6 class="card-title">${groupName}</h6>
                            <div class="d-flex justify-content-between">
                                <small>Loans:</small>
                                <strong>${stats.count}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Total:</small>
                                <strong>RWF ${stats.total.toLocaleString()}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Approved:</small>
                                <strong>RWF ${stats.approved.toLocaleString()}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Pending:</small>
                                <strong>RWF ${stats.pending.toLocaleString()}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function loadAdminMeetings() {
            try {
                await loadGroupFilters();
                
                const groupId = document.getElementById('groupFilterMeetings').value;
                const url = groupId ? `/api/admin/meetings??group_id=${groupId}` : '/api/admin/meetings?';
                const data = await apiCall(url);
                
                if (data && data.meetings) {
                    const tbody = document.getElementById('adminMeetingsTable');
                    tbody.innerHTML = data.meetings.map(meeting => `
                        <tr>
                            <td>${meeting.group_name}</td>
                            <td>${new Date(meeting.meeting_date).toLocaleString()}</td>
                            <td><span class="badge bg-info">${meeting.meeting_type}</span></td>
                            <td>${meeting.agenda || 'No agenda'}</td>
                            <td><span class="badge ${meeting.status === 'completed' ? 'bg-success' : meeting.status === 'cancelled' ? 'bg-danger' : 'bg-warning'}">${meeting.status}</span></td>
                            <td>${meeting.attendance_count || 0}/${meeting.total_members || 0}</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" onclick="viewMeetingDetails(${meeting.id})">View Details</button>
                            </td>
                        </tr>
                    `).join('');
                    
                    loadGroupMeetingStats(data.meetings);
                }
            } catch (error) {
                console.error('Error loading admin meetings:', error);
                document.getElementById('adminMeetingsTable').innerHTML = '<tr><td colspan="7">No meetings found</td></tr>';
            }
        }

        async function loadGroupMeetingStats(meetings) {
            const statsDiv = document.getElementById('groupMeetingStats');
            const groupStats = {};
            
            meetings.forEach(meeting => {
                if (!groupStats[meeting.group_name]) {
                    groupStats[meeting.group_name] = { total: 0, completed: 0, scheduled: 0 };
                }
                groupStats[meeting.group_name].total++;
                if (meeting.status === 'completed') {
                    groupStats[meeting.group_name].completed++;
                } else if (meeting.status === 'scheduled') {
                    groupStats[meeting.group_name].scheduled++;
                }
            });
            
            statsDiv.innerHTML = Object.entries(groupStats).map(([groupName, stats]) => `
                <div class="col-md-4 mb-3">
                    <div class="card border-warning">
                        <div class="card-body">
                            <h6 class="card-title">${groupName}</h6>
                            <div class="d-flex justify-content-between">
                                <small>Total Meetings:</small>
                                <strong>${stats.total}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Completed:</small>
                                <strong>${stats.completed}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Scheduled:</small>
                                <strong>${stats.scheduled}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function loadAdminAttendance() {
            try {
                await loadGroupFilters();
                
                const groupId = document.getElementById('groupFilterAttendance').value;
                const url = groupId ? `/api/admin/attendance?group_id=${groupId}` : '/api/admin/attendance';
                const data = await apiCall(url);
                
                if (data && data.attendance) {
                    const tbody = document.getElementById('adminAttendanceTable');
                    tbody.innerHTML = data.attendance.map(record => `
                        <tr>
                            <td>${record.group_name}</td>
                            <td>${new Date(record.meeting_date).toLocaleDateString()}</td>
                            <td>${record.full_name}</td>
                            <td><span class="badge ${record.attendance_status === 'present' ? 'bg-success' : 'bg-danger'}">${record.attendance_status}</span></td>
                            <td>RWF ${record.fine_amount || 0}</td>
                        </tr>
                    `).join('');
                    
                    loadGroupAttendanceStats(data.attendance);
                }
            } catch (error) {
                console.error('Error loading admin attendance:', error);
                document.getElementById('adminAttendanceTable').innerHTML = '<tr><td colspan="5">No attendance records found</td></tr>';
            }
        }

        async function loadGroupAttendanceStats(attendance) {
            const statsDiv = document.getElementById('groupAttendanceStats');
            const groupStats = {};
            
            attendance.forEach(record => {
                if (!groupStats[record.group_name]) {
                    groupStats[record.group_name] = { total: 0, present: 0, absent: 0, fines: 0 };
                }
                groupStats[record.group_name].total++;
                if (record.attendance_status === 'present') {
                    groupStats[record.group_name].present++;
                } else {
                    groupStats[record.group_name].absent++;
                }
                groupStats[record.group_name].fines += record.fine_amount || 0;
            });
            
            statsDiv.innerHTML = Object.entries(groupStats).map(([groupName, stats]) => `
                <div class="col-md-4 mb-3">
                    <div class="card border-info">
                        <div class="card-body">
                            <h6 class="card-title">${groupName}</h6>
                            <div class="d-flex justify-content-between">
                                <small>Total Records:</small>
                                <strong>${stats.total}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Present:</small>
                                <strong>${stats.present}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Absent:</small>
                                <strong>${stats.absent}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small>Total Fines:</small>
                                <strong>RWF ${stats.fines.toLocaleString()}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function loadGroupFilters() {
            try {
                const data = await apiCall('/api/admin/groups');
                if (data && data.groups) {
                    const filters = ['groupFilterContributions', 'groupFilterLoans', 'groupFilterMeetings', 'groupFilterAttendance', 'groupFilterFines'];
                    filters.forEach(filterId => {
                        const select = document.getElementById(filterId);
                        if (select) {
                            select.innerHTML = '<option value="">All Groups</option>' +
                                data.groups.map(group => `<option value="${group.id}">${group.group_name}</option>`).join('');
                        }
                    });
                }
            } catch (error) {
                console.error('Error loading group filters:', error);
            }
        }

        function viewLoanDetails(loanId) {
            alert(`View details for loan ${loanId} - Would show comprehensive loan information`);
        }

        function viewMeetingDetails(meetingId) {
            alert(`View details for meeting ${meetingId} - Would show comprehensive meeting information`);
        }

        
        function getAdminStatusColor(status) {
            switch(status) {
                case 'approved': return 'bg-success';
                case 'rejected': return 'bg-danger';
                case 'paid': return 'bg-primary';
                case 'defaulted': return 'bg-warning';
                default: return 'bg-secondary';
            }
        }

        async function loadAdminMeetings() {
            try {
                // This would need an API endpoint to get all meetings across all groups
                document.getElementById('adminMeetingsTable').innerHTML = '<tr><td colspan="6">All meetings will be displayed here (API endpoint needed)</td></tr>';
            } catch (error) {
                console.error('Error loading admin meetings:', error);
            }
        }

        async function loadAdminAttendance() {
            try {
                // This would need an API endpoint to get all attendance records across all groups
                document.getElementById('adminAttendanceTable').innerHTML = '<tr><td colspan="5">All attendance records will be displayed here (API endpoint needed)</td></tr>';
            } catch (error) {
                console.error('Error loading admin attendance:', error);
            }
        }

        async function loadAdminFines() {
            try {
                // This would need an API endpoint to get all fines across all groups
                document.getElementById('adminFinesTable').innerHTML = '<tr><td colspan="8">All fines will be displayed here (API endpoint needed)</td></tr>';
            } catch (error) {
                console.error('Error loading admin fines:', error);
            }
        }

        // Update showSection to handle all sections
        function showSection(sectionName, event) {
            // Hide all sections
            document.querySelectorAll('.section-content').forEach(section => {
                section.style.display = 'none';
            });
            
            // Remove active class from all nav items
            document.querySelectorAll('.list-group-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // Show selected section
            const selectedSection = document.getElementById(sectionName + '-section');
            if (selectedSection) {
                selectedSection.style.display = 'block';
            }
            
            // Add active class to clicked nav item
            if (event && event.target) {
                event.target.classList.add('active');
            }
            
            // Load section data
            switch(sectionName) {
                case 'dashboard':
                    loadDashboard();
                    break;
                case 'groups':
                    loadGroups();
                    break;
                case 'chiefs':
                    loadChiefs();
                    break;
                case 'members':
                    loadMembers();
                    break;
                case 'contributions':
                    loadAdminContributions();
                    break;
                case 'loans':
                    loadAdminLoans();
                    break;
                case 'meetings':
                    loadAdminMeetings();
                    break;
                case 'attendance':
                    loadAdminAttendance();
                    break;
                case 'fines':
                    loadAdminFines();
                    break;
                case 'reports':
                    loadReports();
                    break;
                case 'settings':
                    loadSettings();
                    break;
            }
        }

        // Load dashboard on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadDashboard();
        });
    </script>
</body>
</html>
