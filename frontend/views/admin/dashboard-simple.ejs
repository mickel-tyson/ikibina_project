        async function loadAvailableGroupsForChief() {
            try {
                const data = await apiCall('/api/admin/groups');
                if (data && data.groups) {
                    const select = document.querySelector('#createChiefForm select[name="group_id"]');
                    select.innerHTML = '<option value="">Select a group...</option>' +
                        data.groups.filter(group => !group.chief_id).map(group => 
                            `<option value="${group.id}">${group.group_name} - ${group.group_code} (${group.district || 'No district'})</option>`
                        ).join('');
                    
                    // Add onchange event to show group information
                    select.onchange = function() {
                        const selectedGroupId = this.value;
                        if (selectedGroupId) {
                            showGroupInformation(selectedGroupId);
                        } else {
                            hideGroupInformation();
                        }
                    };
                }
            } catch (error) {
                console.error('Error loading groups for chief assignment:', error);
            }
        }

