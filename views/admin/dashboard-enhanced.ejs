        function updateContributionStats(contributions) {
            const total = contributions.reduce((sum, c) => sum + parseFloat(c.amount || 0), 0);
            const thisMonth = contributions.filter(c => {
                const contribDate = new Date(c.date);
                const now = new Date();
                return contribDate.getMonth() === now.getMonth() && contribDate.getFullYear() === now.getFullYear();
            }).reduce((sum, c) => sum + parseFloat(c.amount || 0), 0);
            const pending = contributions.filter(c => c.status === 'pending').length;
            const defaulters = contributions.filter(c => c.status === 'overdue').length;

            document.getElementById('totalContributions').textContent = `RWF ${total.toLocaleString()}`;
            document.getElementById('thisMonthContributions').textContent = `RWF ${thisMonth.toLocaleString()}`;
            document.getElementById('pendingContributions').textContent = pending;
            document.getElementById('defaulters').textContent = defaulters;
        }

