    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
    <script>
        let currentData = {
            groups: [],
            chiefs: [],
            members: [],
            attendance: [],
            notifications: [],
            fines: [],
            reports: [],
            auditLogs: []
        };
        let charts = {};

        // Authentication check
        let authChecked = false;
        function checkAuth() {
            if (authChecked) {
                console.log('Auth already checked, preventing redirect loop');
                return JSON.parse(sessionStorage.getItem('user') || '{}');
            }
            
            const user = sessionStorage.getItem('user');
            console.log('Checking auth, user:', user);
            if (!user) {
                console.log('No user found, redirecting to login');
                window.location.href = '/login';
                return false;
            }
            try {
                const parsedUser = JSON.parse(user);
                console.log('User authenticated:', parsedUser);
                authChecked = true;
                return parsedUser;
            } catch (error) {
                console.error('Error parsing user data:', error);
                sessionStorage.removeItem('user');
                window.location.href = '/login';
                return false;
            }
        }

        async function apiCall(url, options = {}) {
            const defaultOptions = {
                headers: {
                    'Content-Type': 'application/json'
                }
            };
            
            const finalOptions = {
                ...defaultOptions,
                ...options,
                headers: {
                    ...defaultOptions.headers,
                    ...options.headers
                }
            };
            
            try {
                const response = await fetch(url, finalOptions);
                
                // Don't clear sessionStorage on 401, let the auth check handle it
                if (!response.ok) {
                    console.error('API call failed:', response.status, response.statusText);
                    return null;
                }
                
                return await response.json();
            } catch (error) {
                console.error('API call error:', error);
                return null;
            }
        }

        function logout() {
            sessionStorage.removeItem('user');
            window.location.href = '/login';
        }

        // Section Management
        function showSection(evt, section) {
            if (evt && typeof evt.preventDefault === 'function') {
                evt.preventDefault();
            }
            const sections = ['dashboard', 'groups', 'chiefs', 'members', 'contributions', 'loans', 'attendance', 'notifications', 'fines', 'reports', 'audit'];
            sections.forEach(s => {
                const element = document.getElementById(`${s}-section`);
                if (element) {
                    element.classList.toggle('active', s === section);
                    element.style.display = s === section ? 'block' : 'none';
                }
            });

            const navLinks = document.querySelectorAll('.sidebar .nav-link');
            navLinks.forEach(link => link.classList.remove('active'));
            
            // Find the clicked link and add active class
            const clickedLink = evt?.target?.closest?.('.nav-link');
            if (clickedLink) {
                clickedLink.classList.add('active');
            }

            loadData(section);
        }

        async function loadData(section) {
            switch(section) {
                case 'dashboard':
                    loadDashboard();
                    break;
                case 'groups':
                    loadGroups();
                    break;
                case 'chiefs':
                    loadChiefs();
                    break;
                case 'members':
                    loadMembers();
                    break;
                case 'contributions':
                    loadContributions();
                    break;
                case 'loans':
                    loadLoans();
                    break;
                case 'attendance':
                    loadAttendance();
                    break;
                case 'notifications':
                    loadNotifications();
                    break;
                case 'fines':
                    loadFines();
                    break;
                case 'reports':
                    loadReports();
                    break;
                case 'audit':
                    loadAuditLogs();
                    break;
            }
        }

        // Dashboard Functions
        async function loadDashboard() {
            // Simulate dashboard stats
            const stats = {
                totalGroups: (currentData.groups || []).length,
                activeGroups: (currentData.groups || []).filter(g => g.status === 'active').length,
                totalChiefs: (currentData.chiefs || []).length,
                totalMembers: (currentData.members || []).length,
                totalContributions: 15000,
                totalLoans: 5000
            };
            
            if (stats) {
                document.getElementById('totalGroups').textContent = stats.totalGroups;
                document.getElementById('activeGroups').textContent = stats.activeGroups;
                document.getElementById('totalChiefs').textContent = stats.totalChiefs;
                document.getElementById('totalMembers').textContent = stats.totalMembers;
                document.getElementById('totalContributions').textContent = `RWF ${stats.totalContributions.toLocaleString()}`;
                document.getElementById('totalLoans').textContent = stats.totalLoans;
                
                // Initialize charts
                initializeCharts();
            }
