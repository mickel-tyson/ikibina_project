                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        ${report.headers.map(h => `<th>${h}</th>`).join('')}
                                    </tr>
                                </thead>
                                <tbody>
                                    ${report.data.map(row => `
                                        <tr>
                                            ${row.map(cell => `<td>${cell}</td>`).join('')}
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-primary" onclick="downloadReport('${report.type}')">
                                <i class="bi bi-download"></i> Download PDF
                            </button>
                            <button class="btn btn-success" onclick="downloadReportExcel('${report.type}')">
                                <i class="bi bi-file-excel"></i> Download Excel
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        // Audit Logs Functions
        function loadAuditLogs() {
            const auditLogs = currentData.auditLogs || [];
            if (auditLogs.length > 0) {
                displayAuditLogs(auditLogs);
            } else {
                // Show empty state
                const tbody = document.getElementById('auditTable');
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No audit logs yet</td></tr>';
            }
        }
        
        function displayAuditLogs(auditLogs) {
            const tbody = document.getElementById('auditTable');
            tbody.innerHTML = auditLogs.map(log => `
                <tr>
                    <td>${new Date(log.timestamp).toLocaleDateString()}</td>
                    <td>${new Date(log.created_at).toLocaleString()}</td>
                    <td>${log.user_name}</td>
                    <td><span class="badge bg-info">${log.action}</span></td>
                    <td>${log.group_name || 'N/A'}</td>
                    <td>${log.details}</td>
                    <td>${log.ip_address}</td>
                </tr>
            `).join('');
        }

        function exportAuditLogs() {
            const filter = document.getElementById('auditFilter')?.value || 'all';
            showNotification('Exporting audit logs...', 'info');
            // Implementation would trigger file download
        }

        // Group Management Functions
        async function activateGroup(groupId) {
            const response = await apiCall(`/api/admin/groups/${groupId}/activate`, {
                method: 'POST'
            });
            if (response) {
                showNotification('Group activated successfully', 'success');
                loadGroups();
            }
        }

        async function deactivateGroup(groupId) {
            const response = await apiCall(`/api/admin/groups/${groupId}/deactivate`, {
                method: 'POST'
            });
            if (response) {
                showNotification('Group deactivated successfully', 'success');
                loadGroups();
            }
        }

        // Utility Functions
        function refreshData() {
            const activeSection = document.querySelector('.section-content.active').id.replace('-section', '');
            loadData(activeSection);
            showNotification('Data refreshed', 'info');
        }

        function exportData(format) {
            showNotification(`Exporting as ${format.toUpperCase()}...`, 'info');
            // Implementation would go here
        }

        function showNotification(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        function updateGroupDropdown() {
            const groups = currentData.groups || [];
            const dropdowns = document.querySelectorAll('#chiefGroup, #memberGroup, #notificationGroup');
            dropdowns.forEach(dropdown => {
                if (dropdown) {
                    dropdown.innerHTML = '<option value="">Select Group</option>' + 
                        groups
                            .map(group => {
                                const label = group.group_name || group.name || 'Unnamed Group';
                                return `<option value="${group.id}">${label}</option>`;
                            })
                            .join('');
                }
            });
        }

        // Event Listeners
        document.getElementById('createChiefModal')?.addEventListener('shown.bs.modal', function () {
            // Refresh group dropdown every time the modal opens
            updateGroupDropdown();
        });
        document.getElementById('notificationTarget')?.addEventListener('change', function() {
            const notificationGroup = document.getElementById('notificationGroup');
            if (this.value === 'group') {
                notificationGroup.style.display = 'block';
            } else {
                notificationGroup.style.display = 'none';
            }
        });

        document.getElementById('auditFilter')?.addEventListener('change', loadAuditLogs);

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a moment for sessionStorage to be ready
            setTimeout(() => {
                const auth = checkAuth();
                if (auth) {
                    console.log('Page loaded with authenticated user:', auth);
                    loadDashboard();
                    // Load initial data and update dropdowns
                    updateGroupDropdown();
                    
                    // Show dashboard section by default
                    showSection(null, 'dashboard');
                }
            }, 100);
        });
    </script>
</body>
</html>
