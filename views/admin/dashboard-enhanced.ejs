        // Chiefs Functions
        async function createChief() {
            const form = document.getElementById('createChiefForm');
            
            // Get form values directly by ID to ensure correct field mapping
            const fullName = document.getElementById('chiefFullName').value.trim();
            const email = document.getElementById('chiefEmail').value.trim();
            const phone = document.getElementById('chiefPhone').value.trim();
            const chiefGroup = document.getElementById('chiefGroup').value;
            
            // Validate required fields
            if (!fullName || !email || !phone) {
                alert('Please fill in all required fields (Full Name, Email, and Phone)');
                return;
            }
            
            // Validate email format
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                alert('Please enter a valid email address');
                return;
            }
            
            // Validate phone format (basic validation)
            if (phone.length < 10) {
                alert('Please enter a valid phone number (at least 10 digits)');
                return;
            }
            
            const data = {
                full_name: fullName,
                email: email,
                phone: phone,
                chiefGroup: chiefGroup
            };
            
            // Simulate successful chief creation
            const newChief = {
                id: Date.now(),
                full_name: data.full_name,
                email: data.email,
                phone: data.phone,
                role: 'chief',
                status: 'active',
                created_at: new Date().toISOString(),
                assigned_group: data.chiefGroup
            };
            
            bootstrap.Modal.getInstance(document.getElementById('createChiefModal')).hide();
            form.reset();
            showNotification('Chief created successfully', 'success');
            
            // Add to current chiefs list
            const currentChiefs = currentData.chiefs || [];
            currentChiefs.push(newChief);
            currentData.chiefs = currentChiefs;
            
            displayChiefs(currentChiefs);
        }

