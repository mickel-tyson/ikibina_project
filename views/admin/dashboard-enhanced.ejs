        // Save Edited Group
        async function saveEditedGroup() {
            const form = document.getElementById('editGroupForm');
            const groupId = parseInt(form.dataset.groupId);
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            
            if (!data.group_name || !data.group_code || !data.district) {
                alert('Please fill in all required fields');
                return;
            }
            
            // Find and update the group
            const groups = currentData.groups || [];
            const groupIndex = groups.findIndex(g => g.id === groupId);
            
            if (groupIndex === -1) {
                showNotification('Group not found', 'error');
                return;
            }
            
            // Update group data
            groups[groupIndex] = {
                ...groups[groupIndex],
                group_name: data.group_name,
                group_code: data.group_code,
                district: data.district,
                sector: data.sector,
                cell: data.cell,
                village: data.village,
                contribution_amount: data.contribution_amount
            };
            
            currentData.groups = groups;
            
            // Hide modal and refresh
            bootstrap.Modal.getInstance(document.getElementById('editGroupModal')).hide();
            showNotification('Group updated successfully', 'success');
            displayGroups(groups);
            updateGroupDropdown();
        }

